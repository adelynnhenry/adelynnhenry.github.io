---
import DocumentLayout from "../document/Layout.astro";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
const { frontmatter, site } = Astro.props;
---

<DocumentLayout site={site} frontmatter={frontmatter}>
  <Header site={site} frontmatter={frontmatter} />
  <slot />
  <Footer site={site} frontmatter={frontmatter} />
</DocumentLayout>
