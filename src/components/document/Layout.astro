---
const { site, frontmatter } = Astro.props;
---

<!doctype html>
<html>
  <head>
    <meta charset="UTF-8" />
    <meta
      name="description"
      content={site.title +
        " - " +
        site.description +
        " - " +
        frontmatter.title}
    />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>
      {site.title + (frontmatter.title ? " - " + frontmatter.title : "")}
    </title>
  </head>
  <body class={frontmatter.type}>
    <slot />
  </body>
</html>
